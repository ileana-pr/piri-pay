# crypto wallet addresses for receiving tips
# 
# BITCOIN:
#   - Mainnet addresses: start with 1, 3, or bc1
#   - Testnet addresses: start with m, n, 2, or tb1
#   - Your wallet must be on the same network (mainnet/testnet) as the address
#   - Testnet BTC faucet: https://bitcoinfaucet.uo1.net/
VITE_BTC_ADDRESS=your-bitcoin-address-here
#
# ETHEREUM & POLYGON:
#   - Addresses are the same format (0x...) across all networks
#   - But accounts are separate on each network (mainnet vs testnet)
#   - IMPORTANT: Your wallet must be on the same network as configured in web3Config.ts
#   
#   Current setup uses MAINNET (real ETH/MATIC):
#     - Ethereum Mainnet: real ETH, real money
#     - Polygon Mainnet: real MATIC, real money
#     - Switch your wallet (MetaMask/etc) to "Ethereum Mainnet" or "Polygon Mainnet"
#   
#   For testing, you'd need to modify src/lib/web3Config.ts to use testnets:
#     - Ethereum Sepolia testnet: free ETH from https://sepoliafaucet.com/
#     - Polygon Mumbai testnet: free MATIC from https://faucet.polygon.technology/
#     - Then switch wallet to matching testnet
VITE_ETH_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
#
# SOLANA:
#   - Addresses are the same format across all networks
#   - But accounts are separate on each network (devnet vs mainnet)
VITE_SOL_ADDRESS=YourSolanaAddressHere

# solana network endpoint configuration
# IMPORTANT: Your wallet must be on the same network as this endpoint!
# 
# For development/testing (use free devnet tokens):
#   VITE_SOLANA_ENDPOINT=https://api.devnet.solana.com
#   - Switch your wallet (Phantom/Solflare) to "Testnet" mode
#   - Get free devnet SOL from: https://faucet.solana.com
#   - Your address is the same, but devnet account is separate from mainnet
#
# For production (real SOL, real money):
#   VITE_SOLANA_ENDPOINT=https://api.mainnet-beta.solana.com
#   - Switch your wallet to "Mainnet" mode
#   - Use real SOL from your wallet
#
# Default: devnet (safe default for development)
VITE_SOLANA_ENDPOINT=https://api.devnet.solana.com

# payment app handles (optional)
VITE_CASHAPP_HANDLE=yourcashtag
VITE_VENMO_HANDLE=yourvenmo
VITE_ZELLE_HANDLE=your@email.com
